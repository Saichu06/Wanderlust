<!DOCTYPE html>
<html>
<head>
    <title>Create New Listing</title>
</head>
<body>

<h2>Create a New Listing</h2>

<form action="/listings" method="POST">

    <label>Title</label>
    <input type="text" name="listing[title]" required>
    <br><br>

    <label>Description</label>
    <textarea name="listing[description]" required></textarea>
    <br><br>

    <label>Price</label>
    <input type="number" name="listing[price]" required>
    <br><br>

    <label>Location</label>
    <input type="text" name="listing[location]" required>
    <br><br>

    <label>Country</label>
    <input type="text" name="listing[country]" required>
    <br><br>

    <button type="submit">Add Listing</button>

</form>

</body>
</html>